# Normalize line endings: store text as LF in the repository.
* text=auto eol=lf

# Explicit text types
*.js   text eol=lf
*.mjs  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.svg  text eol=lf

# Binary assets (never normalized)
*.png  binary
*.jpg  binary
*.ico  binary
*.woff2 binary
